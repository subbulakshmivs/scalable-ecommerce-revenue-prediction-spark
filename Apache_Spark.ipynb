          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Remove null values\n",
        "df = df.dropna()\n",
        "\n",
        "# Remove duplicates\n",
        "df = df.dropDuplicates()"
      ],
      "metadata": {
        "id": "q6bgCvJ2JwyW"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Create delivery delay feature\n",
        "df = df.withColumn(\n",
        "    \"delivery_days\",\n",
        "    datediff(col(\"delivery_date\"), col(\"order_date\"))\n",
        ")\n",
        "\n",
        "# Extract time features\n",
        "df = df.withColumn(\"year\", year(\"order_date\"))\n",
        "df = df.withColumn(\"month\", month(\"order_date\"))"
      ],
      "metadata": {
        "id": "Xd1ppaDBJ687"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Total Revenue\n",
        "df.select(sum(\"total_sales\")).show()\n",
        "\n",
        "# Revenue by category\n",
        "df.groupBy(\"category\") \\\n",
        "  .agg(sum(\"total_sales\").alias(\"Total_Revenue\")) \\\n",
        "  .show()\n",
        "\n",
        "# Top 10 products\n",
        "df.groupBy(\"product_name\") \\\n",
        "  .agg(sum(\"total_sales\").alias(\"Total_Revenue\")) \\\n",
        "  .orderBy(desc(\"Total_Revenue\")) \\\n",
        "  .show(10)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "HIGAJd-4J8kY",
        "outputId": "ced813ac-a46f-4a82-d3dc-7c00b3336495"
      },
      "execution_count": 8,
