            "|       level|1404669.9319000002|\n",
            "+------------+------------------+\n",
            "only showing top 10 rows\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Identify categorical columns\n",
        "categorical_cols = [\"category\", \"sub_category\", \"brand\", \"payment_method\", \"city\", \"state\"]\n",
        "\n",
        "indexers = [\n",
        "    StringIndexer(inputCol=col, outputCol=col+\"_index\", handleInvalid=\"skip\")\n",
        "    for col in categorical_cols\n",
        "]\n",
        "\n",
        "# Numerical columns\n",
        "numerical_cols = [\"quantity\", \"unit_price\", \"discount\", \"shipping_cost\", \"delivery_days\", \"month\"]\n",
        "\n",
        "# Feature assembler\n",
        "assembler = VectorAssembler(\n",
        "    inputCols=[col+\"_index\" for col in categorical_cols] + numerical_cols,\n",
        "    outputCol=\"features\"\n",
        ")\n",
        "\n",
        "# Scaling\n",
        "scaler = StandardScaler(inputCol=\"features\", outputCol=\"scaled_features\")"
      ],
      "metadata": {
        "id": "Pyq48cDyJ-GS"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "train_data, test_data = df.randomSplit([0.8, 0.2], seed=42)"
      ],
      "metadata": {
        "id": "xA6D9BQcKBvn"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "rf = RandomForestRegressor(\n",
        "    featuresCol=\"scaled_features\",\n",
        "    labelCol=\"total_sales\"\n",
        ")"
      ],
      "metadata": {
        "id": "zG1rufleKFso"
      },
      "execution_count": 11,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from google.colab import drive\n",
        "drive.mount('/content/drive')"
      ],
      "metadata": {
        "id": "-6TzaEzqLD2a"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "pipeline = Pipeline(stages=indexers + [assembler, scaler, rf])\n",
        "\n",
        "model = pipeline.fit(train_data)"
      ],
      "metadata": {
        "id": "SdiaodVBKIKo"
      },
      "execution_count": 12,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "predictions = model.transform(test_data)\n",
        "\n",
        "predictions.select(\"total_sales\", \"prediction\").show(10)"
